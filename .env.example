# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080
LOG_LEVEL=info
# JWT secret is required; the API server will not start if this is empty.
JWT_SECRET=

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=tradingagent
DATABASE_URL=
DATABASE_POOL_SIZE=10
DATABASE_SSL_MODE=disable

# Redis
REDIS_URL=redis://redis:6379/0

# LLM defaults
LLM_DEFAULT_PROVIDER=openai
LLM_DEEP_THINK_MODEL=gpt-5.2
LLM_QUICK_THINK_MODEL=gpt-5-mini
LLM_TIMEOUT=30s
LLM_DEBATE_TIMEOUT=
LLM_CACHE_ENABLED=
STALE_RUN_TTL=
SIGNAL_FALLBACK_MODE=

# LLM resilience (PR: llm-resilience)
LLM_FALLBACK_PROVIDER=
LLM_FALLBACK_MODEL=
LLM_RETRY_MAX_ATTEMPTS=2
LLM_CALL_TIMEOUT=5m
LLM_BUDGET_REQUESTS_DAY=0
LLM_BUDGET_TOKENS_DAY=0
LLM_THROTTLE_CONCURRENCY=4

# LLM providers (configure at least one API key)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-7-sonnet-latest
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.5-flash
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=
OPENROUTER_MODEL=openai/gpt-4.1-mini
XAI_API_KEY=
XAI_BASE_URL=
XAI_MODEL=grok-3-mini
# llama-line bearer auth token for the Ollama-compatible broker.
OLLAMA_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Data providers
POLYGON_API_KEY=
ALPHA_VANTAGE_API_KEY=
ALPHA_VANTAGE_RATE_LIMIT_PER_MINUTE=5
# Parsed/validated today but not wired into the runtime provider factory yet.
FINNHUB_API_KEY=
FINNHUB_RATE_LIMIT_PER_MINUTE=60

# Brokers
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_PAPER_MODE=true
# Binance market data is public; these creds are for broker execution only.
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_PAPER_MODE=true

# Notifications
NOTIFY_TELEGRAM_BOT_TOKEN=
NOTIFY_TELEGRAM_CHAT_ID=
NOTIFY_SMTP_HOST=
NOTIFY_SMTP_PORT=587
NOTIFY_SMTP_USERNAME=
NOTIFY_SMTP_PASSWORD=
NOTIFY_EMAIL_FROM=
NOTIFY_EMAIL_TO=
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=
NOTIFY_PAGERDUTY_WEBHOOK_URL=
NOTIFY_PAGERDUTY_WEBHOOK_SECRET=
# Prefer NOTIFY_DISCORD_*; legacy DISCORD_WEBHOOK_* aliases still load.
NOTIFY_DISCORD_SIGNAL_WEBHOOK_URL=
NOTIFY_DISCORD_DECISION_WEBHOOK_URL=
NOTIFY_DISCORD_ALERT_WEBHOOK_URL=

# Alert routing
ALERT_PIPELINE_FAILURE_THRESHOLD=3
ALERT_PIPELINE_FAILURE_CHANNELS=telegram,email
ALERT_CIRCUIT_BREAKER_CHANNELS=telegram
ALERT_LLM_PROVIDER_DOWN_ERROR_RATE_THRESHOLD=0.5
ALERT_LLM_PROVIDER_DOWN_WINDOW=5m
ALERT_LLM_PROVIDER_DOWN_CHANNELS=telegram
ALERT_HIGH_LATENCY_THRESHOLD=120s
ALERT_HIGH_LATENCY_CHANNELS=email
ALERT_KILL_SWITCH_CHANNELS=telegram
ALERT_DB_CONNECTION_CHANNELS=email,pagerduty

# Risk defaults
RISK_MAX_POSITION_SIZE_PCT=0.10
RISK_MAX_DAILY_LOSS_PCT=0.02
RISK_MAX_DRAWDOWN_PCT=0.10
RISK_MAX_OPEN_POSITIONS=10
RISK_CIRCUIT_BREAKER_THRESHOLD=0.05
RISK_CIRCUIT_BREAKER_COOLDOWN=15m
TRADING_AGENT_KILL=

# Feature flags
ENABLE_SCHEDULER=false
SCHEDULER_JOB_TIMEOUT=45m
ENABLE_REDIS_CACHE=true
ENABLE_AGENT_MEMORY=true
ENABLE_LIVE_TRADING=false
