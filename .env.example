# -----------------------------------------------------------------------------
# Augr environment template
# -----------------------------------------------------------------------------
# Copy to .env for local/NUC runs and fill secrets locally. Keep this file free
# of real credentials.

# -----------------------------------------------------------------------------
# Application / API
# -----------------------------------------------------------------------------
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080
AUGR_API_PORT=3030
AUGR_WEB_PORT=3029
LOG_LEVEL=info
# JWT secret is required; the API server will not start if this is empty.
JWT_SECRET=
# Admin-only endpoints such as POST /api/v1/risk/breaker/reset require this.
ADMIN_API_KEY=

# CLI/API clients
TRADINGAGENT_API_URL=http://127.0.0.1:8080
TRADINGAGENT_TOKEN=
TRADINGAGENT_API_KEY=

# -----------------------------------------------------------------------------
# Database / cache
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=tradingagent
DATABASE_URL=
DATABASE_POOL_SIZE=10
DATABASE_SSL_MODE=disable
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# LLM models and resilience
# -----------------------------------------------------------------------------
LLM_DEFAULT_PROVIDER=openai
LLM_DEEP_THINK_MODEL=gpt-5.2
LLM_QUICK_THINK_MODEL=gpt-5-mini
LLM_TIMEOUT=30s
LLM_DEBATE_TIMEOUT=
LLM_CACHE_ENABLED=
STALE_RUN_TTL=
SIGNAL_FALLBACK_MODE=

LLM_FALLBACK_PROVIDER=
LLM_FALLBACK_MODEL=
LLM_RETRY_MAX_ATTEMPTS=2
LLM_CALL_TIMEOUT=5m
LLM_BUDGET_REQUESTS_DAY=0
LLM_BUDGET_TOKENS_DAY=0
LLM_THROTTLE_CONCURRENCY=4

# Configure at least one API-backed LLM provider, or use Ollama/llama-line.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-7-sonnet-latest
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.5-flash
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4.1-mini
XAI_API_KEY=
XAI_BASE_URL=
XAI_MODEL=grok-3-mini

# llama-line bearer auth token for the Ollama-compatible broker.
OLLAMA_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Embeddings default to OLLAMA_BASE_URL when EMBEDDING_BASE_URL is empty.
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_BASE_URL=http://10.0.0.50:11434
EMBEDDING_TIMEOUT=30s

# -----------------------------------------------------------------------------
# Market data providers
# -----------------------------------------------------------------------------
# Polygon REST API key for stock/options data provider chain.
POLYGON_API_KEY=
POLYGON_FILES_ID=
ALPHA_VANTAGE_API_KEY=
ALPHA_VANTAGE_RATE_LIMIT_PER_MINUTE=5
FINNHUB_API_KEY=
FINNHUB_RATE_LIMIT_PER_MINUTE=60
FMP_API_KEY=
FMP_RATE_LIMIT_PER_MINUTE=4
NEWSAPI_API_KEY=
TRADIER_API_KEY=
TRADIER_API_KEY_PROD=
TRADIER_ACCOUNT_NUMBER=
TRADIER_SANDBOX=true

# Polygon RPC/WS endpoints enable the optional Polymarket mempool signal source.
# Leave both blank to disable it.
POLYGON_RPC_URL=
POLYGON_WS_URL=

# -----------------------------------------------------------------------------
# Brokers / execution
# -----------------------------------------------------------------------------
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_PAPER_MODE=true

# Binance market data is public; these creds are for broker execution only.
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_PAPER_MODE=true

# Polymarket retail API credentials are required for live Polymarket trading.
# The app reads POLYMARKET_KEY_ID + POLYMARKET_SECRET_KEY. It does not read
# POLYMARKET_SECRET_ID; if your credential is labeled "secret", put that value
# in POLYMARKET_SECRET_KEY.
POLYMARKET_KEY_ID=
POLYMARKET_SECRET_KEY=
POLYMARKET_API_BASE_URL=https://api.polymarket.us
POLYMARKET_GATEWAY_BASE_URL=https://gateway.polymarket.us
POLYMARKET_CLOB_URL=https://clob.polymarket.com

# -----------------------------------------------------------------------------
# Polymarket surfers-bot market-data feed / recorder
# -----------------------------------------------------------------------------
# Feed is off by default. If POLYMARKET_WS_URL is blank, the app default is
# wss://ws-subscriptions-clob.polymarket.com/ws/.
POLYMARKET_WS_ENABLED=false
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/
POLYMARKET_WS_CONNECTIONS=100
POLYMARKET_WS_SLUGS=

# Recorder requires POLYMARKET_WS_ENABLED=true and schema 39+ TimescaleDB tables.
POLYMARKET_RECORDER_ENABLED=false

# -----------------------------------------------------------------------------
# Risk controls
# -----------------------------------------------------------------------------
RISK_MAX_POSITION_SIZE_PCT=0.10
RISK_MAX_DAILY_LOSS_PCT=0.02
RISK_MAX_DRAWDOWN_PCT=0.10
RISK_MAX_OPEN_POSITIONS=10
RISK_CIRCUIT_BREAKER_THRESHOLD=0.05
RISK_CIRCUIT_BREAKER_COOLDOWN=15m
TRADING_AGENT_KILL=

# Polymarket-specific risk limits.
RISK_POLYMARKET_MAX_SINGLE_EXPOSURE_PCT=0.05
RISK_POLYMARKET_MAX_TOTAL_EXPOSURE_PCT=0.30
RISK_POLYMARKET_MAX_POSITION_USDC=0
RISK_POLYMARKET_MIN_LIQUIDITY_USDC=1000
RISK_POLYMARKET_MAX_SPREAD_PCT=0.10
RISK_POLYMARKET_MIN_DAYS_TO_RESOLUTION=1

# -----------------------------------------------------------------------------
# Notifications / webhooks
# -----------------------------------------------------------------------------
NOTIFY_TELEGRAM_BOT_TOKEN=
NOTIFY_TELEGRAM_CHAT_ID=
NOTIFY_SMTP_HOST=
NOTIFY_SMTP_PORT=587
NOTIFY_SMTP_USERNAME=
NOTIFY_SMTP_PASSWORD=
NOTIFY_EMAIL_FROM=
NOTIFY_EMAIL_TO=
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=
NOTIFY_PAGERDUTY_WEBHOOK_URL=
NOTIFY_PAGERDUTY_WEBHOOK_SECRET=

# Canonical Discord webhook variables. Legacy DISCORD_* aliases still load in
# code for old deployments, but new env files should use NOTIFY_DISCORD_*.
NOTIFY_DISCORD_SIGNAL_WEBHOOK_URL=
NOTIFY_DISCORD_DECISION_WEBHOOK_URL=
NOTIFY_DISCORD_ALERT_WEBHOOK_URL=

# Alert routing
ALERT_PIPELINE_FAILURE_THRESHOLD=3
ALERT_PIPELINE_FAILURE_CHANNELS=telegram,email
ALERT_CIRCUIT_BREAKER_CHANNELS=telegram
ALERT_LLM_PROVIDER_DOWN_ERROR_RATE_THRESHOLD=0.5
ALERT_LLM_PROVIDER_DOWN_WINDOW=5m
ALERT_LLM_PROVIDER_DOWN_CHANNELS=telegram
ALERT_HIGH_LATENCY_THRESHOLD=120s
ALERT_HIGH_LATENCY_CHANNELS=email
ALERT_KILL_SWITCH_CHANNELS=telegram
ALERT_DB_CONNECTION_CHANNELS=email,pagerduty

# -----------------------------------------------------------------------------
# Feature flags / schedulers
# -----------------------------------------------------------------------------
ENABLE_SCHEDULER=false
SCHEDULER_JOB_TIMEOUT=45m
ENABLE_REDIS_CACHE=true
ENABLE_AGENT_MEMORY=true
ENABLE_LIVE_TRADING=false

ENABLE_TICKER_DISCOVERY=false
TICKER_DISCOVERY_CRON=30 10 * * 1-5
TICKER_DISCOVERY_MIN_ADV=100000
TICKER_DISCOVERY_MAX_TICKERS=30

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=

# -----------------------------------------------------------------------------
# Test/smoke helpers
# -----------------------------------------------------------------------------
DB_URL=
RUN_SMOKE_TEST=0
SMOKE_BASE_URL=http://127.0.0.1:8080
SMOKE_DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/tradingagent?sslmode=disable
SMOKE_JWT_SECRET=
